package templates

import (
	"geminirouter/pkg/config"
)

templ HeadersTab(items []config.CustomHeader) {
	<div class="space-y-8">
		<!-- Header & Actions -->
		<div class="sm:flex sm:items-center sm:justify-between">
			<div>
				<h1 class="text-2xl font-bold tracking-tight text-gray-900">Custom Headers</h1>
				<p class="mt-2 text-sm text-gray-700">
					Manage and enforce custom metadata or session headers client applications must send.
				</p>
			</div>
			<div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none">
				<button
					hx-get="/admin/headers/new"
					hx-target="#modal-container"
					class="block rounded-md bg-blue-600 px-3 py-2 text-center text-sm font-semibold text-white shadow-sm hover:bg-blue-500 transition"
				>
					Add Header Rule
				</button>
			</div>
		</div>

		<!-- Expandable Custom Headers Usage Guide -->
		<details class="group border border-gray-200 rounded-lg bg-white shadow-sm overflow-hidden">
			<summary class="flex items-center justify-between cursor-pointer p-4 bg-gray-50 hover:bg-gray-100 transition select-none">
				<div class="flex items-center gap-3">
					<div class="p-2 bg-blue-50 text-blue-600 rounded-lg">
						<svg class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />
						</svg>
					</div>
					<div class="text-left">
						<span class="text-sm font-semibold text-gray-900">How to use custom headers in client integrations</span>
						<p class="text-xs text-gray-500">View HTTP request headers injection and official SDK code examples</p>
					</div>
				</div>
				<div class="text-gray-400 group-open:rotate-180 transition-transform duration-200">
					<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
					</svg>
				</div>
			</summary>
			
			<div class="p-6 border-t border-gray-200 bg-white space-y-6 text-sm text-gray-600 text-left">
				<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
					<!-- Quick reference -->
					<div class="md:col-span-1 space-y-4 border-r border-gray-100 pr-6">
						<div>
							<h4 class="text-xs font-bold uppercase tracking-wider text-gray-500">Verification Protocol</h4>
							<p class="mt-1 text-xs text-gray-500 leading-relaxed">
								Custom headers are checked at the smart router gateway before requests are matched to routing policies. If a required header fails validation, the request is rejected with a clear <code class="bg-gray-100 text-gray-800 px-1 rounded text-[10px]">400 Bad Request</code>.
							</p>
						</div>
						<div>
							<h4 class="text-xs font-bold uppercase tracking-wider text-gray-500">Active Headers Defined</h4>
							<ul class="mt-2 space-y-1 text-xs">
								if len(items) == 0 {
									<li class="text-gray-400 italic">No headers defined currently.</li>
								} else {
									for _, item := range items {
										<li class="flex items-center gap-1.5">
											<span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
											<code class="font-mono text-gray-700">{ item.Name }</code>
											if item.Required {
												<span class="text-[10px] text-red-500 font-semibold">(Required)</span>
											}
										</li>
									}
								}
							</ul>
						</div>
					</div>

					<!-- Code examples -->
					<div class="md:col-span-2 space-y-4">
						<h4 class="text-xs font-bold uppercase tracking-wider text-gray-500">Integration Examples (Passing Custom Headers)</h4>
						
						<div class="space-y-4">
							<!-- curl example -->
							<div class="rounded-lg overflow-hidden bg-gray-950">
								<div class="bg-gray-900 px-4 py-1.5 flex justify-between items-center">
									<span class="text-xs font-semibold text-gray-400 font-mono">cURL / HTTP API</span>
								</div>
								<pre class="p-4 text-xs font-mono text-gray-300 overflow-x-auto whitespace-pre-wrap"><code>curl -X POST "<span class="dynamic-origin-url">http://localhost:8080</span>/v1/models/gemini-2.5-flash:generateContent" \
  -H "x-goog-api-key: YOUR_API_KEY" \
  -H "Content-Type: application/json" \
  for _, item := range items {
  -H "{ item.Name }: YOUR_VALUE" \
  }
  -d '{"{"}contents": [{"{"}parts":[{"{"}text": "Hello Gemini!"{"}"}]{"}"}]{"}"}'</code></pre>
							</div>

							<!-- Multi-language Grid -->
							<div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
								<!-- Python -->
								<div class="rounded-lg overflow-hidden bg-gray-950">
									<div class="bg-gray-900 px-3 py-1 flex justify-between items-center">
										<span class="text-[10px] font-semibold text-gray-400 font-mono">Python SDK</span>
									</div>
									<pre class="p-3 text-[11px] font-mono text-gray-300 overflow-x-auto"><code>from google import genai

client = genai.Client(
    api_key="YOUR_KEY",
    http_options={"{"}
        "api_endpoint": "<span class="dynamic-origin-url">http://localhost:8080</span>",
        "headers": {"{"}
            for _, item := range items {
            "{ item.Name }": "YOUR_VALUE",
            }
        {"}"}
    {"}"}
)</code></pre>
								</div>

								<!-- Go -->
								<div class="rounded-lg overflow-hidden bg-gray-950">
									<div class="bg-gray-900 px-3 py-1 flex justify-between items-center">
										<span class="text-[10px] font-semibold text-gray-400 font-mono">Go SDK</span>
									</div>
									<pre class="p-3 text-[11px] font-mono text-gray-300 overflow-x-auto"><code>import "google.golang.org/api/option"

client, err := genai.NewClient(ctx,
    option.WithAPIKey("YOUR_KEY"),
    option.WithEndpoint("<span class="dynamic-origin-url">http://localhost:8080</span>"),
    option.WithHTTPHeader(map[string][]string{"{"}
        for _, item := range items {
        "{ item.Name }": {"{"}"YOUR_VALUE"{"}"},
        }
    {"}"}),
)</code></pre>
								</div>

								<!-- JS/TS -->
								<div class="rounded-lg overflow-hidden bg-gray-950">
									<div class="bg-gray-900 px-3 py-1 flex justify-between items-center">
										<span class="text-[10px] font-semibold text-gray-400 font-mono">JS/TS SDK</span>
									</div>
									<pre class="p-3 text-[11px] font-mono text-gray-300 overflow-x-auto"><code>import {"{"} GoogleGenAI {"}"} from '@google/genai';

const ai = new GoogleGenAI({"{"}
  apiKey: "YOUR_KEY",
  baseUrl: "<span class="dynamic-origin-url">http://localhost:8080</span>",
  headers: {"{"}
    for _, item := range items {
    "{ item.Name }": "YOUR_VALUE",
    }
  {"}"}
{"}"});</code></pre>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</details>

		<!-- Table of Custom Headers -->
		<div class="bg-white shadow-sm border border-gray-200 rounded-lg overflow-hidden">
			<div class="inline-block min-w-full align-middle">
				<table class="min-w-full divide-y divide-gray-300">
					<thead class="bg-gray-50">
						<tr>
							<th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-6">Header Name</th>
							<th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Scope</th>
							<th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Description</th>
							<th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Required</th>
							<th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Validation Type</th>
							<th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Value Pattern</th>
							<th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6">
								<span class="sr-only">Actions</span>
							</th>
						</tr>
					</thead>
					<tbody class="divide-y divide-gray-200 bg-white">
						if len(items) == 0 {
							<tr>
								<td colspan="7" class="text-center py-8 text-sm text-gray-500 italic">
									No Custom Headers defined. Define headers to apply request enforcement.
								</td>
							</tr>
						} else {
							for _, item := range items {
								<tr class="hover:bg-gray-50 transition-colors">
									<td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm sm:pl-6 font-mono font-semibold text-gray-900">
										{ item.Name }
									</td>
									<td class="whitespace-nowrap px-3 py-4 text-sm">
										if item.AppID == "" || item.AppID == "global" {
											<span class="inline-flex items-center rounded-md bg-green-50 px-2 py-1 text-xs font-medium text-green-700 ring-1 ring-inset ring-green-600/20">
												Global
											</span>
										} else {
											<span class="inline-flex items-center rounded-md bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-700/10">
												{ item.AppID }
											</span>
										}
									</td>
									<td class="px-3 py-4 text-sm text-gray-600 max-w-xs truncate">
										{ item.Description }
									</td>
									<td class="whitespace-nowrap px-3 py-4 text-sm">
										if item.Required {
											<span class="inline-flex items-center rounded-md bg-red-50 px-2 py-1 text-xs font-medium text-red-700 ring-1 ring-inset ring-red-600/20">
												Yes
											</span>
										} else {
											<span class="inline-flex items-center rounded-md bg-gray-50 px-2 py-1 text-xs font-medium text-gray-600 ring-1 ring-inset ring-gray-500/10">
												No (Optional)
											</span>
										}
									</td>
									<td class="whitespace-nowrap px-3 py-4 text-sm text-gray-900 font-medium">
										{ item.Validation }
									</td>
									<td class="px-3 py-4 text-sm text-gray-500 font-mono text-xs truncate max-w-xs">
										if item.ValuePattern != "" {
											{ item.ValuePattern }
										} else {
											<span class="text-gray-400 italic">N/A</span>
										}
									</td>
									<td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6">
										<button
											hx-delete={ "/admin/headers/delete?id=" + item.ID }
											hx-confirm={ "Are you sure you want to remove custom header rule " + item.Name + "?" }
											hx-target="closest tr"
											hx-swap="outerHTML"
											class="text-red-600 hover:text-red-900 transition font-semibold"
										>
											Delete
										</button>
									</td>
								</tr>
							}
						}
					</tbody>
				</table>
			</div>
		</div>

		<!-- Modal Target Anchor -->
		<div id="modal-container"></div>
	</div>
}
