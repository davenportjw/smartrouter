# ==============================================================================
# 🌌 Gemini Smart Router - Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' before running or deploying the application:
#   cp .env.sample .env
# ==============================================================================

# ------------------------------------------------------------------------------
# 👤 USER-PROVIDED REQUIRED CONFIGURATIONS
# ------------------------------------------------------------------------------

# The ID of your Google Cloud Platform (GCP) project.
# Mandatory for both deployment and local upstream integration.
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"

# The port number on which the backend proxy will listen (defaults to 8080).
PORT=8080

# The default location/region to resolve/route Gemini model requests.
GEMINI_LOCATION="us-central1"

# (Optional) Set to "true" to run locally with a mock JSON database (data/local_db.json)
# without connecting to Google Cloud Firestore. Note: run_local.sh sets this automatically.
LOCAL_DEV="false"

# Comma-separated list of email domains or specific email addresses authorized
# to access the Admin Portal. Mandatory for security; no default values are provided.
ALLOWED_EMAIL_DOMAINS="yourcompany.com,your-email@gmail.com"

# A secure token used to authenticate REST API communication between the frontend
# dashboard and the backend proxy API (admin routes).
# 👉 POPULATION INFO:
#   Leave this blank. When you run './deploy.sh', it will automatically generate
#   a secure 32-character alphanumeric token for you and write it to '.env'.
#   For local development, 'run_local.sh' automatically sets this to a default 
#   bypass token.
BACKEND_SHARED_SECRET=""


# ------------------------------------------------------------------------------
# 🤖 FIREBASE CLIENT WEB SDK CONFIGURATIONS (SYSTEM-GENERATED OR MANUAL)
# ------------------------------------------------------------------------------
# 👉 HOW TO POPULATE:
#
# Option A (Recommended - Fully Automated):
#   Leave these EXACT placeholder values intact. When you run `./deploy.sh`, the
#   script will automatically:
#     1. Link Firebase to your GCP project (if not already enabled).
#     2. Register a Web Application named "Gemini Router Admin" for you.
#     3. Fetch all Firebase client credentials.
#     4. Automatically write them back to your local `.env` file!
#
# Option B (Manual Configuration):
#   If configuring manually without `./deploy.sh`, create a Web Application in your
#   Firebase Console (https://console.firebase.google.com/) and copy the config here.

FIREBASE_API_KEY="AIzaSyYourFirebaseWebApiKey"
FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
FIREBASE_PROJECT_ID="your-gcp-project-id"
FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
FIREBASE_MESSAGING_SENDER_ID="123456789"
FIREBASE_APP_ID="1:1234:web:abcd"
