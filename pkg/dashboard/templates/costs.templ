package templates

import "fmt"

templ CostsTab(vm CostsViewModel) {
	<div class="space-y-8 animate-fadeIn">
		<!-- Header -->
		<div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 border-b border-gray-200 pb-5">
			<div>
				<h1 class="text-2xl font-bold tracking-tight text-gray-950">Cost Analytics & Token Budgeting</h1>
				<p class="mt-2 text-sm text-gray-500">
					Real-time estimated model expenditure breakouts by Vertex AI model type, client, and individual session.
				</p>
			</div>
			<div class="flex items-center gap-2 self-start md:self-center">
				<button onclick="window.location.reload()" class="rounded-md bg-white px-3 py-1.5 text-xs font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition">
					Refresh Ledger
				</button>
			</div>
		</div>

		<!-- Cost KPI Grid -->
		<div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
			<!-- Cumulative Spend -->
			<div class="relative overflow-hidden rounded-2xl bg-white px-6 pb-6 pt-5 border border-gray-200/80 shadow-sm hover:shadow-md transition-shadow duration-200">
				<dt>
					<div class="absolute rounded-lg bg-emerald-50 p-2 text-emerald-600">
						<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.779.779a3.75 3.75 0 0 0 5.333 0L16.5 15m-6.75-6 2.675-2.675a3.75 3.75 0 0 1 5.333 0L18 7.125M4.5 18.75h15" />
						</svg>
					</div>
					<p class="ml-12 truncate text-sm font-medium text-gray-500">Total Estimated Spend</p>
				</dt>
				<dd class="ml-12 flex items-baseline pb-0">
					<p class="text-2xl font-semibold tracking-tight text-gray-900">{ fmt.Sprintf("$%.4f", vm.TotalSpend) }</p>
					<span class="ml-2 text-xs font-semibold text-gray-400">USD</span>
				</dd>
			</div>

			<!-- Input Tokens -->
			<div class="relative overflow-hidden rounded-2xl bg-white px-6 pb-6 pt-5 border border-gray-200/80 shadow-sm hover:shadow-md transition-shadow duration-200">
				<dt>
					<div class="absolute rounded-lg bg-blue-50 p-2 text-blue-600">
						<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9 9V4.5M9 9H4.5M9 9 3.75 3.75M9 15v4.5M9 15H4.5M9 15l-5.25 5.25M15 9V4.5M15 9h4.5M15 9l5.25-5.25M15 15v4.5M15 15h4.5M15 15l5.25 5.25" />
						</svg>
					</div>
					<p class="ml-12 truncate text-sm font-medium text-gray-500">Input Tokens Volume</p>
				</dt>
				<dd class="ml-12 flex items-baseline pb-0">
					<p class="text-2xl font-semibold tracking-tight text-gray-900">{ fmt.Sprintf("%d", vm.TotalTokensInput) }</p>
					<span class="ml-2 text-xs font-semibold text-gray-400">tokens</span>
				</dd>
			</div>

			<!-- Output Tokens -->
			<div class="relative overflow-hidden rounded-2xl bg-white px-6 pb-6 pt-5 border border-gray-200/80 shadow-sm hover:shadow-md transition-shadow duration-200">
				<dt>
					<div class="absolute rounded-lg bg-purple-50 p-2 text-purple-600">
						<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
						</svg>
					</div>
					<p class="ml-12 truncate text-sm font-medium text-gray-500">Output Tokens Volume</p>
				</dt>
				<dd class="ml-12 flex items-baseline pb-0">
					<p class="text-2xl font-semibold tracking-tight text-gray-900">{ fmt.Sprintf("%d", vm.TotalTokensOutput) }</p>
					<span class="ml-2 text-xs font-semibold text-gray-400">tokens</span>
				</dd>
			</div>

			<!-- Cost per 1K Reqs -->
			<div class="relative overflow-hidden rounded-2xl bg-white px-6 pb-6 pt-5 border border-gray-200/80 shadow-sm hover:shadow-md transition-shadow duration-200">
				<dt>
					<div class="absolute rounded-lg bg-orange-50 p-2 text-orange-600">
						<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H12m0 0H3.75m1.5 0v-.75a.75.75 0 0 1 .75-.75h.75m-1.5 1.5h.375c.621 0 1.125-.504 1.125-1.125V16.5a9 9 0 0 0-9-9M3.75 18.75a9 9 0 0 1 9-9M16.5 16.5h.008v.008h-.008V16.5Zm.621-2.25H18.75v1.875h-.75v-.75h-.75v.75h-.75v-1.875ZM12 13.5h.008v.008H12V13.5Zm.621-2.25h1.129v1.875h-.75v-.75h-.75v.75h-.75v-1.875ZM6.75 16.5H9v1.875H8.25v-.75H7.5v.75H6.75v-1.875Zm.621-2.25H9.75v1.875H9v-.75H8.25v.75H7.5v-1.875Z" />
						</svg>
					</div>
					<p class="ml-12 truncate text-sm font-medium text-gray-500">Avg Cost / 1K Requests</p>
				</dt>
				<dd class="ml-12 flex items-baseline pb-0">
					<p class="text-2xl font-semibold tracking-tight text-gray-900">{ fmt.Sprintf("$%.4f", vm.AvgCostPer1K) }</p>
				</dd>
			</div>
		</div>

		<!-- Spend Breakouts -->
		<div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
			<!-- Model Pie Chart -->
			<div class="rounded-2xl border border-gray-200/80 bg-white p-6 shadow-sm">
				<div class="flex items-center justify-between border-b border-gray-100 pb-4 mb-6">
					<div>
						<h3 class="text-base font-semibold text-gray-900">Spend by Model Type</h3>
						<p class="text-xs text-gray-500 mt-0.5">Percentage distribution of API expenditure</p>
					</div>
					<span class="inline-flex items-center rounded-full bg-blue-50 px-2.5 py-0.5 text-xs font-medium text-blue-700">
						Donut Chart
					</span>
				</div>
				<div class="h-[220px] flex items-center justify-center">
					@templ.Raw(vm.ModelCostSVG)
				</div>
			</div>

			<!-- Client Progress Bars -->
			<div class="rounded-2xl border border-gray-200/80 bg-white p-6 shadow-sm">
				<div class="flex items-center justify-between border-b border-gray-100 pb-4 mb-6">
					<div>
						<h3 class="text-base font-semibold text-gray-900">Spend by Client Application</h3>
						<p class="text-xs text-gray-500 mt-0.5">Top consuming client credentials</p>
					</div>
					<span class="inline-flex items-center rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-medium text-emerald-700">
						Relative Share
					</span>
				</div>
				<div class="h-[220px]">
					@templ.Raw(vm.ClientCostSVG)
				</div>
			</div>
		</div>

		<!-- Session Ledger Audit Table -->
		<div class="rounded-2xl border border-gray-200/80 bg-white shadow-sm overflow-hidden">
			<div class="border-b border-gray-100 px-6 py-4">
				<h3 class="text-base font-semibold text-gray-900">Detailed Sessions Billing Ledger</h3>
				<p class="text-xs text-gray-500 mt-0.5">A live, transparent audit trail of the most recent 50 proxied request sessions</p>
			</div>
			<div class="overflow-x-auto">
				<table class="min-w-full divide-y divide-gray-200">
					<thead class="bg-gray-50">
						<tr>
							<th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Timestamp</th>
							<th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Session ID</th>
							<th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Client ID</th>
							<th scope="col" class="px-6 py-3.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Routed Model</th>
							<th scope="col" class="px-6 py-3.5 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Input Tokens</th>
							<th scope="col" class="px-6 py-3.5 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Output Tokens</th>
							<th scope="col" class="px-6 py-3.5 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Est. Cost (USD)</th>
						</tr>
					</thead>
					<tbody class="divide-y divide-gray-150 bg-white">
						for _, sess := range vm.RecentSessions {
							<tr class="hover:bg-gray-50/85 transition duration-150">
								<td class="px-6 py-4 whitespace-nowrap text-xs text-gray-600">{ sess.Time }</td>
								<td class="px-6 py-4 whitespace-nowrap text-xs font-mono font-semibold text-blue-600">{ sess.SessionID }</td>
								<td class="px-6 py-4 whitespace-nowrap text-xs font-medium text-gray-800">{ sess.ClientID }</td>
								<td class="px-6 py-4 whitespace-nowrap text-xs">
									if sess.ModelRouted == "gemini-2.5-pro" || sess.ModelRouted == "gemini-1.5-pro" {
										<span class="inline-flex items-center rounded-md bg-purple-50 px-2 py-0.5 text-xs font-medium text-purple-700 ring-1 ring-inset ring-purple-700/10">
											{ sess.ModelRouted }
										</span>
									} else {
										<span class="inline-flex items-center rounded-md bg-blue-50 px-2 py-0.5 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-700/10">
											{ sess.ModelRouted }
										</span>
									}
								</td>
								<td class="px-6 py-4 whitespace-nowrap text-xs text-right text-gray-500 font-mono">{ fmt.Sprintf("%d", sess.InputTokens) }</td>
								<td class="px-6 py-4 whitespace-nowrap text-xs text-right text-gray-500 font-mono">{ fmt.Sprintf("%d", sess.OutputTokens) }</td>
								<td class="px-6 py-4 whitespace-nowrap text-xs text-right font-semibold text-emerald-600 font-mono">{ fmt.Sprintf("$%.5f", sess.EstimatedCost) }</td>
							</tr>
						}
					</tbody>
				</table>
			</div>
		</div>
	</div>
}
